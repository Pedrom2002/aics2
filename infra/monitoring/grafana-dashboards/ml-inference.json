{
  "title": "CS2 Analytics — ML Inference",
  "uid": "cs2-ml-inference",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["cs2", "ml"],
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(ml_inference_total, model)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Inferences / sec",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ml_inference_total{model=~\"$model\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p95 inference time",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ml_inference_duration_seconds_bucket{model=~\"$model\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Model error rate",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ml_inference_errors_total{model=~\"$model\"}[5m])) / sum(rate(ml_inference_total{model=~\"$model\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache hit ratio (parse cache)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(parse_cache_hits_total[5m])) / (sum(rate(parse_cache_hits_total[5m])) + sum(rate(parse_cache_misses_total[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Inference latency p95 by model",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(ml_inference_duration_seconds_bucket{model=~\"$model\"}[5m])))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Inferences/sec per model",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 13 },
      "targets": [
        {
          "expr": "sum by (model) (rate(ml_inference_total{model=~\"$model\"}[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    }
  ]
}
