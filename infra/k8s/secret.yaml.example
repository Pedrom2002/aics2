# Template only — DO NOT commit real secrets.
# Apply via: kubectl apply -f secret.yaml  (after replacing values)
# Or use sealed-secrets / external-secrets in production.
apiVersion: v1
kind: Secret
metadata:
  name: cs2-analytics-secrets
  namespace: cs2-analytics
type: Opaque
stringData:
  POSTGRES_USER: "cs2user"
  POSTGRES_PASSWORD: "REPLACE_ME"
  POSTGRES_DSN: "postgresql+asyncpg://cs2user:REPLACE_ME@postgres:5432/cs2analytics"
  REDIS_PASSWORD: ""
  JWT_SECRET_KEY: "REPLACE_ME_LONG_RANDOM_STRING"
  JWT_REFRESH_SECRET_KEY: "REPLACE_ME_LONG_RANDOM_STRING"
  STRIPE_SECRET_KEY: "sk_live_REPLACE"
  STRIPE_WEBHOOK_SECRET: "whsec_REPLACE"
  S3_ACCESS_KEY: "REPLACE"
  S3_SECRET_KEY: "REPLACE"
  S3_BUCKET: "cs2-analytics-demos"
  S3_ENDPOINT: "https://s3.amazonaws.com"
  HLTV_USER_AGENT: "cs2-analytics-bot/1.0"
